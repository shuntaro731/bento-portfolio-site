---
import shuntaroLogo from "../assets/shuntaro.svg";

const navItems = ["Profile", "Tokushima", "PR"];
---

<header class="relative bg-[#f5f0f0] p-16 text-black">
  <div class="flex items-center justify-between">
    <a href="/" class="block">
      <img class="h-5 w-auto" src={shuntaroLogo.src} alt="shuntaroのlogo" />
    </a>

    <nav
      class="fixed bottom-16 left-1/2 z-50 flex -translate-x-1/2 items-center gap-1 rounded-full bg-[#ebe5e5] p-1 text-sm font-bold sm:absolute sm:bottom-auto sm:top-1/2 sm:-translate-y-1/2"
      aria-label="Main navigation"
    >
      <span
        data-nav-indicator
        class="absolute bottom-1 left-0 top-1 rounded-full bg-white transition-all duration-300 ease-out motion-reduce:transition-none"
        aria-hidden="true"
      ></span>
      {
        navItems.map((item, index) => (
          <a
            href={`#${item.toLowerCase()}`}
            data-nav-link
            class="relative z-10 rounded-full px-4 py-2 leading-none transition-colors hover:text-black/70"
            aria-current={index === 0 ? "page" : undefined}
          >
            {item}
          </a>
        ))
      }
    </nav>

    <a
      href="mailto:"
      class="text-base font-bold leading-none transition-opacity hover:opacity-70"
    >
      Contact&nbsp;&nbsp;👋
    </a>
  </div>
</header>

<script>
  const navLinks = document.querySelectorAll("[data-nav-link]");
  const navIndicator = document.querySelector("[data-nav-indicator]");

  const setActiveNav = () => {
    const activeHash = location.hash || "#profile";
    let hasActiveLink = false;

    navLinks.forEach((link) => {
      const isActive = link.getAttribute("href") === activeHash;

      if (isActive) {
        hasActiveLink = true;
        link.setAttribute("aria-current", "page");
        if (navIndicator instanceof HTMLElement && link instanceof HTMLElement) {
          navIndicator.style.width = `${link.offsetWidth}px`;
          navIndicator.style.transform = `translateX(${link.offsetLeft}px)`;
        }
        return;
      }

      link.removeAttribute("aria-current");
    });

    if (!hasActiveLink && navIndicator instanceof HTMLElement) {
      navIndicator.style.width = "0";
    }
  };

  setActiveNav();
  document.fonts?.ready.then(setActiveNav);
  window.addEventListener("hashchange", setActiveNav);
  window.addEventListener("resize", setActiveNav);
</script>
