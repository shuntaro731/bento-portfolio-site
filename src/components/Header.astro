---
import shuntaroLogo from "../assets/shuntaro.svg";

const navItems = ["Profile", "Tokushima", "PR"];
---

<header class="w-full bg-[#f5f0f0] pt-16">
  <div class="mx-auto flex w-full max-w-[82rem] items-center justify-between px-6 md:px-8">
    <a href="/" class="block" aria-label="shuntaro home">
      <img class="h-5 w-auto" src={shuntaroLogo.src} alt="shuntaro" />
    </a>

    <nav
      class="absolute left-1/2 hidden -translate-x-1/2 items-center gap-1 rounded-full bg-[#ebe5e5] p-1 font-['Satoshi',Inter,sans-serif] text-[0.8125rem] font-bold text-black sm:flex"
      aria-label="Main navigation"
    >
      {
        navItems.map((item, index) => (
          <a
            href={`#${item.toLowerCase()}`}
            class:list={[
              "rounded-full px-4 py-1.5 leading-none transition-colors hover:bg-white",
              index === 0 && "bg-white",
            ]}
          >
            {item}
          </a>
        ))
      }
    </nav>

    <a
      href="mailto:"
      class="font-['Satoshi',Inter,sans-serif] text-base font-bold leading-none text-black transition-opacity hover:opacity-70"
    >
      Contact 👋
    </a>
  </div>
</header>
