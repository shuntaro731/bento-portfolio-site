---
import spotifyIcon from "../../assets/spotify-logo.svg";

const { class: className = "" } = Astro.props;
---

<article
  class:list={[
    "flex aspect-square min-w-0 flex-col justify-between rounded-4xl bg-white p-6 lg:aspect-auto",
    className,
  ]}
  aria-labelledby="spotify-title"
>
  <!-- アイコン -->
  <img src={spotifyIcon.src} alt="" class="size-11" aria-hidden="true" />

  <div class="min-w-0">
    <p class="text-xs font-bold leading-none text-black/40">最近再生した曲</p>
    <h2 id="spotify-title" class="mt-2 truncate text-2xl font-semibold leading-tight text-black">
      都落ち
    </h2>
    <p class="mt-1 truncate text-xs font-medium leading-tight text-black">ヨルシカ</p>
  </div>
</article>
