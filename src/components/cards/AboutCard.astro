---
import meImage from "../../assets/images/profile-avatar.png";

const {
  class: className = "",
  titleId = "profile-title",
  headingTag = "h1",
  showImage = true,
  image = meImage,
  imageAlt = "Shuntarouの顔アイコン",
  imageClass = "size-16 object-contain sm:size-18",
  prefix = "I'm",
  title = "Shuntaro.",
  suffix = "a developer and designer from Tokushima.",
  description = "こんにちわ、18歳の秦駿太朗です。出身は徳島で、趣味はゴルフ、Podcast、ゲーム(MOBA)などです。よろしくお願いします。",
  truncateTitle,
  clampDescription,
} = Astro.props;
const imageSrc = image?.src ?? image;
const imageWidth = image?.width;
const imageHeight = image?.height;
const Heading = headingTag;
const hasImage = showImage && imageSrc;
const shouldTruncateTitle = truncateTitle ?? hasImage;
const shouldClampDescription = clampDescription ?? hasImage;
const affixClass = "text-sm font-medium";
---

<article
  class:list={[
    "grid size-full overflow-hidden rounded-4xl bg-white",
    hasImage ? "grid-rows-[auto_1fr] p-6" : "p-8",
    className,
  ]}
  aria-labelledby={titleId}
>
  {
    showImage && imageSrc && (
      <img
        src={imageSrc}
        width={imageWidth}
        height={imageHeight}
        alt={imageAlt}
        class={imageClass}
      />
    )
  }

  <div class:list={["min-w-0", hasImage && "mt-5 self-end sm:mt-0"]}>
    <Heading
      id={titleId}
      class:list={[shouldTruncateTitle && "truncate", "leading-tight text-black"]}
    >
      {prefix && <span class={affixClass}>{prefix}</span>}
      {
        title && (
          <span class:list={[prefix && "ml-1", "font-serif-display text-2xl font-bold"]}>
            {title}
          </span>
        )
      }
      {suffix && <span class:list={[(prefix || title) && "ml-1", affixClass]}>{suffix}</span>}
    </Heading>

    <p
      class:list={[
        "mt-3 text-xs font-medium leading-relaxed text-black/40",
        shouldClampDescription && "line-clamp-2",
      ]}
    >
      {description}
    </p>
  </div>
</article>
