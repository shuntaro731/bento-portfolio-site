---
import githubIcon from "../../assets/icons/github-logo.svg";
import CardLink from "./CardLink.astro";

const {
  class: className = "",
  url = "https://github.com/shuntaro731",
  ariaLabel = "GitHubを開く",
  backgroundClass = "bg-card-dark",
  icon: Icon,
  iconClass = "size-14",
  iconStrokeWidth = 2.25,
  image = githubIcon,
  imageAlt = "",
} = Astro.props;
const imageSrc = image?.src ?? image;
const imageWidth = image?.width;
const imageHeight = image?.height;
---

<CardLink
  href={url}
  class:list={[
    "flex items-center justify-center",
    backgroundClass,
    className,
  ]}
  ariaLabel={ariaLabel}
>
  {
    Icon ? (
      <Icon
        class={iconClass}
        strokeWidth={iconStrokeWidth}
        aria-hidden="true"
      />
    ) : (
      <img
        src={imageSrc}
        width={imageWidth}
        height={imageHeight}
        alt={imageAlt}
        class={iconClass}
        aria-hidden="true"
      />
    )
  }
</CardLink>
