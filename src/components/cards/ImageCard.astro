---
import tokushimaImage from "../../assets/images/tokushima-night.jpg";
import CardLink from "./CardLink.astro";

const {
  class: className = "",
  titleId = "tokushima-title",
  label = "live in Tokushima\u00a0\u00a0🏝️",
  image = tokushimaImage,
  imageAlt = "徳島の夜景",
  labelClass = "bg-page",
  url = "",
} = Astro.props;
const imageSrc = image?.src ?? image;
const imageWidth = image?.width;
const imageHeight = image?.height;
const hasImage = Boolean(imageSrc);
---

<CardLink
  href={url || undefined}
  showButton={false}
  class:list={["block", className]}
  aria-labelledby={titleId}
>
  {
    hasImage ? (
      <img
        src={imageSrc}
        width={imageWidth}
        height={imageHeight}
        alt={imageAlt}
        class="size-full object-cover brightness-70 transition duration-700 ease-out group-hover:scale-105 group-hover:brightness-100"
      />
    ) : (
      <div class="grid size-full place-items-center bg-muted-card p-6 text-sm font-bold text-black/45">
        {label}
      </div>
    )
  }

  <h2
    id={titleId}
    class:list={[
      "absolute bottom-6 left-6 max-w-[80%] truncate rounded-xl px-4 py-3 text-sm font-semibold leading-none text-black shadow-sm",
      labelClass,
    ]}
  >
    {label}
  </h2>
</CardLink>
