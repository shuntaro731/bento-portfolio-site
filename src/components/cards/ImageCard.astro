---
import tokushimaImage from "../../assets/images/tokushima-night.jpg";

const {
  class: className = "",
  titleId = "tokushima-title",
  label = "live in Tokushima\u00a0\u00a0🏝️",
  image = tokushimaImage,
  imageAlt = "徳島の夜景",
  labelClass = "bg-page",
  url = "",
} = Astro.props;
const imageSrc = image?.src ?? image;
const imageWidth = image?.width;
const imageHeight = image?.height;
const Element = url ? "a" : "article";
---

<Element
  href={url || undefined}
  target={url ? "_blank" : undefined}
  rel={url ? "noreferrer" : undefined}
  class:list={[
    "group relative size-full overflow-hidden rounded-4xl",
    url && "block transition-opacity hover:opacity-90",
    className,
  ]}
  aria-labelledby={titleId}
>
  <img
    src={imageSrc}
    width={imageWidth}
    height={imageHeight}
    alt={imageAlt}
    class="size-full object-cover brightness-70 transition duration-700 ease-out group-hover:scale-105 group-hover:brightness-100"
  />

  <h2
    id={titleId}
    class:list={[
      "absolute bottom-6 left-6 max-w-[80%] truncate rounded-xl px-4 py-3 text-base font-bold leading-none text-black shadow-sm",
      labelClass,
    ]}
  >
    {label}
  </h2>
</Element>
