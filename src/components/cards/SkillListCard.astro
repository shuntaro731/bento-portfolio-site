---
const {
  class: className = "",
  titleId = "skills-title",
  title = "My skills",
  skills = [],
} = Astro.props;
---

<article
  class:list={[
    "flex aspect-square flex-col items-start rounded-4xl border-7 border-white bg-gradient-to-b from-white via-card-soft to-card-softer p-6",
    className,
  ]}
  aria-labelledby={titleId}
>
  <h2
    id={titleId}
    class="font-serif-display text-2xl font-bold leading-tight text-black"
  >
    {title}
  </h2>
  <ul class="mt-4 space-y-2 text-xs font-bold leading-none text-black/55">
    {
      skills.map((skill) => (
        <li class="flex items-center gap-2.5">
          <span class="size-1 rounded-full bg-black/80" aria-hidden="true" />
          {skill}
        </li>
      ))
    }
  </ul>
</article>
