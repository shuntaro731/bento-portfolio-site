---
import tokushimaImage from "../../assets/images/tokushima-night.jpg";

const { class: className = "" } = Astro.props;
---

<article
  class:list={[
    "group relative size-full overflow-hidden rounded-4xl",
    className,
  ]}
  aria-labelledby="tokushima-title"
>
  <img
    src={tokushimaImage.src}
    width={tokushimaImage.width}
    height={tokushimaImage.height}
    alt="徳島の夜景"
    class="size-full object-cover brightness-60 transition duration-700 ease-out group-hover:scale-105 group-hover:brightness-100"
  />

  <h2
    id="tokushima-title"
    class="absolute bottom-6 left-6 max-w-[80%] truncate rounded-xl bg-page px-4 py-3 text-base font-bold leading-none text-black shadow-sm"
  >
    live in Tokushima&nbsp;&nbsp;🏝️
  </h2>
</article>
