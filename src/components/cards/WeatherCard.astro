---
import { Cloud } from "lucide-astro";

const {
  class: className = "",
  titleId = "weather-title",
  temperature = "19°",
  condition = "にわか雨",
} = Astro.props;
---

<article
  class:list={[
    "relative flex size-full flex-col overflow-hidden rounded-4xl border-7 border-white bg-gradient-to-b from-white via-card-soft to-card-softer p-6 text-black",
    className,
  ]}
  aria-labelledby={titleId}
>
  <Cloud
    class="absolute right-6 top-6 size-12 shrink-0 text-black/25"
    aria-hidden="true"
  />

  <div class="mt-auto">
    <p class="font-serif-display text-5xl font-bold leading-none">
      {temperature}
    </p>
    <p class="mt-2 text-base font-medium leading-none">
      {condition}
    </p>

    <p class="mt-4 text-xs font-bold leading-none text-black/35">
      徳島の気温
    </p>
  </div>
</article>
