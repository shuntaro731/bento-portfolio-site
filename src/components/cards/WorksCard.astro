---
import CardLink from "./CardLink.astro";

const {
  class: className = "",
  title = "My work",
  image,
  imageAlt = "",
  url,
} = Astro.props;
const imageSrc = image?.src ?? image;
const imageWidth = image?.width;
const imageHeight = image?.height;
const hasImage = Boolean(imageSrc);
---

<CardLink
  href={url}
  ariaLabel={title || imageAlt}
  class:list={["block bg-muted-card", className]}
>
  {
    hasImage ? (
      <img
        src={imageSrc}
        width={imageWidth}
        height={imageHeight}
        alt={imageAlt}
        class="size-full object-cover brightness-85 transition duration-700 ease-out group-hover:scale-105 group-hover:brightness-100"
      />
    ) : (
      <div class="grid size-full place-items-center bg-muted-card p-6 text-sm font-bold text-black/45">
        {title}
      </div>
    )
  }
</CardLink>
