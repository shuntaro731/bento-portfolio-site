---
import nobamanImage from "../../assets/images/nobaman-avatar.png";
import CardLink from "./CardLink.astro";

const { class: className = "" } = Astro.props;
const nobamanUrl = "https://www.youtube.com/channel/UCTW2tw0Mhho72MojB1L48IQ";
---

<CardLink
  href={nobamanUrl}
  showButton={false}
  class:list={[
    "flex flex-col justify-between border-7 border-white bg-gradient-to-b from-white to-card-pink p-6",
    className,
  ]}
  aria-labelledby="youtuber-title"
>
  <img
    src={nobamanImage.src}
    width={nobamanImage.width}
    height={nobamanImage.height}
    alt="のばまんのアイコン"
    class="mx-auto size-26 rounded-sm object-cover"
  />

  <div>
    <p class="text-xs font-bold leading-none text-muted-text">好きなYoutuber</p>
    <h2
      id="youtuber-title"
      class="mt-3 truncate text-xl font-bold leading-tight text-black"
    >
      のばまん (nobaman)
    </h2>
  </div>
</CardLink>
