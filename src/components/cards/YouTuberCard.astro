---
import nobamanImage from "../../assets/images/nobaman-avatar.png";

const { class: className = "" } = Astro.props;
const nobamanUrl = "https://www.youtube.com/channel/UCTW2tw0Mhho72MojB1L48IQ";
---

<a
  href={nobamanUrl}
  target="_blank"
  rel="noreferrer"
  class:list={[
    "flex size-full flex-col justify-between rounded-4xl border-7 border-white bg-[linear-gradient(180deg,#ffffff_0%,#fcf4f3_100%)] p-6 transition-opacity hover:opacity-90",
    className,
  ]}
  aria-labelledby="youtuber-title"
>
  <img
    src={nobamanImage.src}
    width={nobamanImage.width}
    height={nobamanImage.height}
    alt="のばまんのアイコン"
    class="mx-auto size-26 rounded-sm object-cover"
  />

  <div>
    <p class="text-xs font-bold leading-none text-[#8c8e8d]">好きなYoutuber</p>
    <h2
      id="youtuber-title"
      class="mt-3 truncate text-xl font-bold leading-tight text-black"
    >
      のばまん (nobaman)
    </h2>
  </div>
</a>
