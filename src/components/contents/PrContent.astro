---
import { ArrowUpRight, Code2, Figma, Flag, Palette } from "lucide-astro";

const figmaUrl = "https://www.figma.com/@shuntaro1";

const skills = [
  "UIデザイン",
  "フロントエンド",
  "Astro / Tailwind",
];
---

<div
  class="grid grid-cols-1 items-start gap-6 sm:grid-cols-[repeat(2,minmax(0,13rem))] lg:grid-cols-[repeat(4,14.5rem)] lg:auto-rows-[14.5rem]"
>
  <article
    class="flex aspect-[463/219] flex-col justify-center rounded-4xl bg-white p-8 sm:col-span-2 lg:col-start-1 lg:row-start-1 lg:aspect-auto lg:h-full"
    aria-labelledby="pr-title"
  >
    <div class="max-w-full">
      <p class="text-base font-normal leading-tight text-black">
        What I’m Passionate About
      </p>
      <h2
        id="pr-title"
        class="mt-4 text-sm font-bold leading-relaxed text-black/55"
      >
        デザインとフロントエンド開発が得意です。
      </h2>
      <p class="mt-3 text-xs font-medium leading-relaxed text-black/45">
        ユーザー体験が素晴らしいコンテンツや、いろんな業界のデザイナーの作品を見ることが好きです。
        このページでは、今まで作ってきた作品や好きなことを仮置きでまとめています。
      </p>
    </div>
  </article>

  <article
    class="flex aspect-square flex-col justify-between rounded-4xl bg-white p-6 sm:col-start-1 lg:col-start-1 lg:row-start-2"
    aria-labelledby="golf-title"
  >
    <span class="grid size-16 place-items-center rounded-full bg-[#d8d8d8] text-black/65">
      <Flag size={26} strokeWidth={2.25} aria-hidden="true" />
    </span>

    <div>
      <h2 id="golf-title" class="text-lg font-bold leading-none text-black">
        Golf
      </h2>
      <p class="mt-4 text-xs font-bold leading-relaxed text-black/60">
        最近ベストスコアを更新して、とても嬉しいです。ドライバーが苦手なので練習中です。
      </p>
    </div>
  </article>

  <article
    class="flex aspect-square flex-col justify-center rounded-4xl bg-white p-6 sm:col-start-2 lg:col-start-2 lg:row-start-2"
    aria-labelledby="skills-title"
  >
    <h2 id="skills-title" class="text-base font-bold leading-tight text-black">
      My skills
    </h2>
    <ul class="mt-5 space-y-3 text-xs font-bold leading-none text-black/60">
      {
        skills.map((skill) => (
          <li class="flex items-center gap-2">
            <span class="size-1.5 rounded-full bg-black/35" aria-hidden="true" />
            {skill}
          </li>
        ))
      }
    </ul>
  </article>

  <a
    href={figmaUrl}
    target="_blank"
    rel="noreferrer"
    class="relative flex aspect-square items-center justify-center rounded-4xl bg-[#242424] text-white transition-opacity hover:opacity-90 lg:col-start-4 lg:row-start-1"
    aria-label="Figmaプロフィールを開く"
  >
    <Figma size={58} strokeWidth={2.25} aria-hidden="true" />

    <span
      class="absolute bottom-4 left-4 grid size-11 place-items-center rounded-full bg-[#f7f1f1] text-black"
      aria-hidden="true"
    >
      <ArrowUpRight size={18} strokeWidth={2.5} />
    </span>
  </a>

  <a
    href={figmaUrl}
    target="_blank"
    rel="noreferrer"
    class="group relative flex aspect-[231/465] flex-col justify-center overflow-hidden rounded-4xl bg-[#d8d8d8] p-6 transition-opacity hover:opacity-90 sm:col-start-1 lg:col-start-3 lg:row-span-2 lg:row-start-1 lg:aspect-auto lg:h-full"
    aria-labelledby="work-design-title"
  >
    <div class="absolute left-5 top-5 grid size-12 place-items-center rounded-2xl bg-white/45 text-black/60">
      <Palette size={22} strokeWidth={2.25} aria-hidden="true" />
    </div>

    <h2
      id="work-design-title"
      class="text-center text-base font-bold leading-tight text-black"
    >
      My work
    </h2>
    <p class="mt-3 text-center text-xs font-bold leading-none text-black/45">
      Design
    </p>

    <span
      class="absolute bottom-4 left-4 grid size-11 place-items-center rounded-full bg-[#f7f1f1] text-black"
      aria-hidden="true"
    >
      <ArrowUpRight size={18} strokeWidth={2.5} />
    </span>
  </a>

  <a
    href="https://github.com/shuntaro731"
    target="_blank"
    rel="noreferrer"
    class="group relative flex aspect-[231/465] flex-col justify-center overflow-hidden rounded-4xl bg-[#d8d8d8] p-6 transition-opacity hover:opacity-90 sm:col-start-2 lg:col-start-4 lg:row-span-2 lg:row-start-2 lg:aspect-auto lg:h-full"
    aria-labelledby="work-code-title"
  >
    <div class="absolute left-5 top-5 grid size-12 place-items-center rounded-2xl bg-white/45 text-black/60">
      <Code2 size={22} strokeWidth={2.25} aria-hidden="true" />
    </div>

    <h2
      id="work-code-title"
      class="text-center text-base font-bold leading-tight text-black"
    >
      My work
    </h2>
    <p class="mt-3 text-center text-xs font-bold leading-none text-black/45">
      Frontend
    </p>

    <span
      class="absolute bottom-4 left-4 grid size-11 place-items-center rounded-full bg-[#f7f1f1] text-black"
      aria-hidden="true"
    >
      <ArrowUpRight size={18} strokeWidth={2.5} />
    </span>
  </a>
</div>
