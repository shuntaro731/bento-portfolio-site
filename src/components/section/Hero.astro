---
import Header from "../Header.astro";
import ProfileCard from "../card/ProfileCard.astro";
import SpotifyCard from "../card/SpotifyCard.astro";
---

<section id="profile" class="min-h-screen bg-[#f5f0f0]">
  <Header />

  <div
    class="mx-auto grid max-w-7xl grid-cols-1 gap-6 px-6 pt-10 md:grid-cols-2 lg:grid-cols-6"
  >
    <ProfileCard class="md:col-span-2 lg:col-span-4" />
    <SpotifyCard class="md:col-span-1 lg:col-span-2" />
  </div>
</section>
